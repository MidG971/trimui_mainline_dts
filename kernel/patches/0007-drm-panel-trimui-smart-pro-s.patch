Subject: [PATCH] drm/panel: add Trimui Smart Pro S DSI panel

Wire up the Trimui Smart Pro S MIPI-DSI panel driver. Driver source is
kernel/drivers/panel-trimui-smart-pro-s.c in this repo; drop it into
drivers/gpu/drm/panel/ before applying.

Apply with: patch -p1 < this file

--- a/drivers/gpu/drm/panel/Kconfig
+++ b/drivers/gpu/drm/panel/Kconfig
@@ -1297,4 +1297,13 @@
 	  Say Y here if you want to enable support for the Xinpeng
 	  XPP055C272 controller for 720x1280 LCD panels with MIPI/RGB/SPI
 	  system interfaces.
+config DRM_PANEL_TRIMUI_SMART_PRO_S
+	tristate "Trimui Smart Pro S MIPI-DSI panel"
+	depends on OF
+	depends on DRM_MIPI_DSI
+	depends on BACKLIGHT_CLASS_DEVICE
+	help
+	  Say Y here to support the MIPI-DSI panel on the Trimui Smart Pro S
+	  handheld (720x1280, 4-lane RGB888, Ilitek/Fitipower-class DDIC).
+
 endmenu
--- a/drivers/gpu/drm/panel/Makefile
+++ b/drivers/gpu/drm/panel/Makefile
@@ -128,3 +128,4 @@
 obj-$(CONFIG_DRM_PANEL_VISIONOX_R66451) += panel-visionox-r66451.o
 obj-$(CONFIG_DRM_PANEL_WIDECHIPS_WS2401) += panel-widechips-ws2401.o
 obj-$(CONFIG_DRM_PANEL_XINPENG_XPP055C272) += panel-xinpeng-xpp055c272.o
+obj-$(CONFIG_DRM_PANEL_TRIMUI_SMART_PRO_S) += panel-trimui-smart-pro-s.o
