# SPDX-License-Identifier: (GPL-2.0-only OR MIT)
# Trimui Smart Pro S (Allwinner A523) — kernel config fragment.
#
# Apply on top of the arm64 defconfig, AFTER the patch series (0001-0014) is in
# the tree (some symbols below are added by those patches / dropped-in drivers):
#   scripts/kconfig/merge_config.sh -m .config <repo>/kernel/trimui.config
#   make ARCH=arm64 olddefconfig
#
# Two layers: (1) board drivers, (2) handheld tuning/optimisation. Layer 2 is the
# no-hardware "daily-driver" tuning; the exact numbers (governors, thermal trips,
# OPP voltages) are still HW-tuned — see docs/THERMAL-DVFS-NOTES.md.

CONFIG_ARCH_SUNXI=y

# ============================ (1) board drivers ============================

# Display pipeline (patches 0001-0008 + dropped-in drivers)
CONFIG_DRM=m
CONFIG_DRM_SUN4I=m
CONFIG_DRM_SUN6I_DSI=m
CONFIG_PHY_SUN6I_MIPI_DPHY=m
CONFIG_PHY_SUN55I_DSI_COMBO=m
CONFIG_DRM_PANEL_TRIMUI_SMART_PRO_S=m
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_PWM_SUN20I=m

# GPU — Mali-G57 / Panfrost (upstream)
CONFIG_DRM_PANFROST=m

# Power / regulators (incl. the tcs4838 big-cluster CPU supply, patch 0014)
CONFIG_REGULATOR=y
CONFIG_REGULATOR_AXP20X=y
CONFIG_REGULATOR_FAN53555=m

# USB: host + Type-C role-switch (patch 0013) + gadget (ethernet-over-USB / adb)
CONFIG_PHY_SUN4I_USB=y
CONFIG_USB_MUSB_HDRC=m
CONFIG_USB_MUSB_SUNXI=m
CONFIG_USB_MUSB_DUAL_ROLE=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_TYPEC=m
CONFIG_TYPEC_TCPM=m
CONFIG_TYPEC_TCPCI=m
CONFIG_TYPEC_RT1711H=m
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=m
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_F_FS=y

# Input: analog sticks (GPADC), side keys (LRADC), userspace pads, vibrator
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_ADC=m
CONFIG_KEYBOARD_SUN4I_LRADC=m
CONFIG_INPUT_UINPUT=y
CONFIG_INPUT_JOYDEV=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_PWM_VIBRA=m

# Audio codec (patches 0009/0010, dropped-in sun55i-codec)
CONFIG_SND=m
CONFIG_SND_SOC=m
CONFIG_SND_SOC_SUN55I_CODEC=m

# Storage: microSD/eMMC + flash-friendly rootfs
CONFIG_MMC=y
CONFIG_MMC_SUNXI=y
CONFIG_F2FS_FS=y

# ===================== (2) handheld tuning / optimisation =====================

# CPU freq: schedutil default + energy-aware scheduling (needs the CPU clock —
# see docs/CPUPLL-NOTES.md — and dynamic-power-coefficient in the DT)
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y
# A523 CPU-PLL clock controller (adopted from ut-slayer, patches 0015-0020) — CPU DVFS
CONFIG_SUN55I_A523_CPU_CCU=y
CONFIG_ENERGY_MODEL=y

# Latency: full preemption for input / emulator responsiveness
CONFIG_PREEMPT=y

# Idle / suspend (battery life)
CONFIG_CPU_IDLE=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_PM=y
CONFIG_SUSPEND=y

# Memory: zram + zswap (zstd) — a 4 GB gaming handheld benefits a lot
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_CRYPTO_LZ4=y

# Thermal: zones + step_wise + IPA, CPU + GPU (devfreq) cooling, PWM fan
CONFIG_THERMAL=y
CONFIG_THERMAL_OF=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_SENSORS_PWM_FAN=m
