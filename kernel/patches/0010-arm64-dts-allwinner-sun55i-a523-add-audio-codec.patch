From 5aba21a6115614d9d7d1ba97ae87a90ecfe6f61c Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Sun, 21 Jun 2026 09:03:33 +0000
Subject: [PATCH] arm64: dts: allwinner: sun55i-a523: add audio codec

Add the audio-codec@7110000 node for the A523 internal audio codec
(allwinner,sun55i-a523-codec): MCU-CCU bus/dac/adc clocks + the audio
PLLs, MCU-CCU reset, mcu_dma DRQ 7 (tx/rx) and IRQ 190. Disabled by
default; boards enable it and add the analog supply.

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index 5afa8d92a..d6e5adfa2 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -991,6 +991,24 @@ mcu_ccu: clock-controller@7102000 {
 			#reset-cells = <1>;
 		};
 
+		codec: audio-codec@7110000 {
+			compatible = "allwinner,sun55i-a523-codec";
+			reg = <0x07110000 0x348>;
+			interrupts = <GIC_SPI 190 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&mcu_ccu CLK_BUS_MCU_AUDIO_CODEC>,
+				 <&mcu_ccu CLK_MCU_AUDIO_CODEC_DAC>,
+				 <&mcu_ccu CLK_MCU_AUDIO_CODEC_ADC>,
+				 <&ccu CLK_PLL_AUDIO0_4X>,
+				 <&mcu_ccu CLK_MCU_PLL_AUDIO1_DIV5>;
+			clock-names = "bus", "dac", "adc", "pll-audio0-4x",
+				      "pll-audio1-div5";
+			resets = <&mcu_ccu RST_BUS_MCU_AUDIO_CODEC>;
+			dmas = <&mcu_dma 7>, <&mcu_dma 7>;
+			dma-names = "tx", "rx";
+			#sound-dai-cells = <0>;
+			status = "disabled";
+		};
+
 		i2s0: i2s@7112000 {
 			compatible = "allwinner,sun55i-a523-i2s",
 				     "allwinner,sun50i-r329-i2s";
-- 
