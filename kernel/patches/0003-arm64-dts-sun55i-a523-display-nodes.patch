Subject: [PATCH] arm64: dts: allwinner: sun55i-a523: add display pipeline nodes

Add the DE3.5 -> TCON-LCD1 -> MIPI-DSI1 -> panel display block to the A523
(sun55iw3) SoC dtsi. Addresses and wiring come from the vendor DTB and the
A523 user manual:

  de@5000000          display engine 3.5  (CLK_BUS_DE/CLK_DE, RST_BUS_DE,
                      PD_DE) - disabled skeleton, NO mainline mixer/CRTC driver
                      yet, so it carries no upstream-bound compatible.
  display-top@5500000 DISPLAY0_TOP / DPSS glue (CLK_BUS_DISPLAY0_TOP,
                      RST_BUS_DISPLAY0_TOP) - disabled skeleton, no driver yet.
  lcd-controller@5502000  TCON-LCD1, allwinner,sun55i-a523-tcon-lcd
                      (ahb=CLK_BUS_TCON_LCD1, tcon-ch0=CLK_TCON_LCD1;
                      resets lcd=RST_BUS_TCON_LCD1, lvds=RST_BUS_LVDS1).
  dsi@5508000         MIPI-DSI host 1, allwinner,sun55i-a523-mipi-dsi
                      (bus=CLK_BUS_MIPI_DSI1, mod=CLK_MIPI_DSI1,
                      reset=RST_BUS_MIPI_DSI1, phy=dsi1_combo_phy).
  phy@5509000         DSI combo D-PHY, allwinner,sun55i-a523-dsi-combo-phy
                      (bus=CLK_COMBOPHY_DSI1, reset shared RST_BUS_MIPI_DSI1).

OF graph: de -> tcon1 -> dsi1 -> panel. tcon1/dsi1/combophy are disabled by
default and enabled per-board. DE/display-top stay disabled until a sun55i
DE3.5 mixer/CRTC driver exists upstream (none today), so nothing scans out
yet; this only puts the pipeline DT in place.

Verified: compiles clean with `make ARCH=arm64 dtbs` (linux 6.19); a board
DTS that #includes the panel fragment resolves &dsi1/&dsi1_combo_phy/&tcon1
and the full OF graph.
Apply with: patch -p1 < this file   (from the kernel source root)

--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -721,6 +721,129 @@
 			};
 		};
 
+		/*
+		 * Display pipeline (DE3.5 -> TCON-LCD1 -> MIPI-DSI1 -> panel).
+		 *
+		 * The DE3.5 mixer/CRTC has no mainline driver yet, so the display
+		 * engine and display-top (DPSS) nodes are skeletons kept disabled;
+		 * they carry no upstream-bound compatible so they cannot mis-probe.
+		 * They exist so the OF graph (de -> tcon1 -> dsi1 -> panel) is
+		 * complete once a DE driver lands. TCON-LCD1, the DSI host and the
+		 * DSI combo-PHY have mainline drivers and are wired for real.
+		 */
+
+		de: display-engine@5000000 {
+			/*
+			 * Allwinner DE3.5 ("display-engine-v350" in the BSP).
+			 * No mainline mixer/CRTC driver exists for sun55i DE3.5,
+			 * so this node is a disabled skeleton: do NOT add a
+			 * compatible that an existing driver would bind to.
+			 */
+			reg = <0x05000000 0x400000>;
+			interrupts = <GIC_SPI 87 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_DE>, <&ccu CLK_DE>;
+			clock-names = "bus", "mod";
+			resets = <&ccu RST_BUS_DE>;
+			power-domains = <&pck600 PD_DE>;
+			status = "disabled";
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				de_out: port@0 {
+					reg = <0>;
+
+					de_out_tcon1: endpoint {
+						remote-endpoint = <&tcon1_in_de>;
+					};
+				};
+			};
+		};
+
+		dpss_top0: display-top@5500000 {
+			/*
+			 * DISPLAY0_TOP (DPSS/TCON-TOP glue, "tcon-top0" in the
+			 * BSP). No mainline driver for the sun55i variant yet;
+			 * disabled skeleton. Provides the bus clock/reset that
+			 * gate the TCON-LCD register interface.
+			 */
+			reg = <0x05500000 0x1000>;
+			clocks = <&ccu CLK_BUS_DISPLAY0_TOP>;
+			clock-names = "bus";
+			resets = <&ccu RST_BUS_DISPLAY0_TOP>;
+			status = "disabled";
+		};
+
+		tcon1: lcd-controller@5502000 {
+			compatible = "allwinner,sun55i-a523-tcon-lcd";
+			reg = <0x05502000 0x1000>;
+			interrupts = <GIC_SPI 92 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_TCON_LCD1>, <&ccu CLK_TCON_LCD1>;
+			clock-names = "ahb", "tcon-ch0";
+			clock-output-names = "tcon-pixel-clock1";
+			resets = <&ccu RST_BUS_TCON_LCD1>, <&ccu RST_BUS_LVDS1>;
+			reset-names = "lcd", "lvds";
+			#clock-cells = <0>;
+			status = "disabled";
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				tcon1_in: port@0 {
+					reg = <0>;
+
+					tcon1_in_de: endpoint {
+						remote-endpoint = <&de_out_tcon1>;
+					};
+				};
+
+				tcon1_out: port@1 {
+					reg = <1>;
+
+					tcon1_out_dsi1: endpoint {
+						remote-endpoint = <&dsi1_in_tcon1>;
+					};
+				};
+			};
+		};
+
+		dsi1: dsi@5508000 {
+			compatible = "allwinner,sun55i-a523-mipi-dsi";
+			reg = <0x05508000 0x1000>;
+			interrupts = <GIC_SPI 95 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_MIPI_DSI1>, <&ccu CLK_MIPI_DSI1>;
+			clock-names = "bus", "mod";
+			resets = <&ccu RST_BUS_MIPI_DSI1>;
+			phys = <&dsi1_combo_phy>;
+			phy-names = "dphy";
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+
+			/*
+			 * Single input port from TCON-LCD1 (mainline sun6i DSI
+			 * binding convention). The DSI->panel link is the DSI bus
+			 * itself: the panel is a child node, not an OF-graph hop.
+			 */
+			port {
+				dsi1_in_tcon1: endpoint {
+					remote-endpoint = <&tcon1_out_dsi1>;
+				};
+			};
+		};
+
+		dsi1_combo_phy: phy@5509000 {
+			compatible = "allwinner,sun55i-a523-dsi-combo-phy";
+			reg = <0x05509000 0x1000>;
+			clocks = <&ccu CLK_COMBOPHY_DSI1>;
+			clock-names = "bus";
+			resets = <&ccu RST_BUS_MIPI_DSI1>;
+			#phy-cells = <0>;
+			status = "disabled";
+		};
+
 		ppu: power-controller@7001400 {
 			compatible = "allwinner,sun55i-a523-ppu";
 			reg = <0x07001400 0x400>;
