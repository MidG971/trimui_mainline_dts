/*
 * Trimui Smart Pro S handheld (board "A523-PRO2-AXP717C").
 * SoC: Allwinner A523 (sun55iw3p1). Base: mainline sun55i-a523.dtsi.
 *
 * WORK IN PROGRESS. Modeled on the upstream sun55i-t527-avaota-a1.dts (same SoC
 * family). Built with the display series in kernel/patches/ applied and
 * trimui-panel.dtsi appended (see kernel/build-trimui-kernel.sh).
 *
 * On board now: PMIC + regulators, storage (microSD/eMMC), USB2, RTC, LEDC RGB
 * array, GPU (Mali-G57 / Panfrost, upstream), MIPI-DSI panel + PWM backlight
 * (via patches), fan + vibrator (PWM), audio codec, LRADC side keys, GPADC
 * analog sticks (2 controllers; gpadc0 upstream v7.2 + gpadc1 via patch), WiFi/BT
 * power sequencing (AIC8800, out-of-tree module). Still pending: USB3 (draft in
 * dts/staging/). See PORTING-NOTES.md for the roadmap.
 *
 * "VERIFY" = needs confirmation by i2c/dump on real hardware before trusting.
 * Rail->consumer map is derived from the vendor DTB where known and otherwise
 * mirrors Avaota A1; the exact Trimui map must be read from the device.
 */

/dts-v1/;

#include "sun55i-a523.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pwm/pwm.h>

/ {
	model = "Trimui Smart Pro S";
	/* T527 is the same die as A523; A523 is what mainline carries. */
	compatible = "trimui,smart-pro-s", "allwinner,sun55i-a523";

	aliases {
		serial0 = &uart0;
		mmc0 = &mmc0;	/* microSD */
		mmc1 = &mmc1;	/* WiFi SDIO */
		mmc2 = &mmc2;	/* eMMC */
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	/*
	 * LiPo pack, 5000 mAh. Values from the vendor DTB: battery-cap 0x1388 =
	 * 5000 mAh, init-chgvol 0x1068 = 4.2 V CV, runtime-chgcur 0x3e8 = 1 A
	 * (the vendor bumps to ~1.95 A in suspend/shutdown). The AXP717 has a
	 * hardware fuel gauge (E-gauge) that reports charge % directly, so mainline's
	 * axp717 battery driver reads SoC from hardware and consumes only the
	 * charge-current + voltage limits below — the vendor's 32-point OCV curve
	 * (pmu_bat_para1..32) is not needed by mainline (kept in FIRMWARE-FINDINGS).
	 * VERIFY the design-min and capacity against the device.
	 */
	battery: battery {
		compatible = "simple-battery";
		voltage-min-design-microvolt = <3400000>;		/* VERIFY */
		voltage-max-design-microvolt = <4200000>;		/* vendor CV = 4.2 V */
		constant-charge-current-max-microamp = <1000000>;	/* 1 A runtime */
		charge-full-design-microamp-hours = <5000000>;		/* 5000 mAh */
	};

	/*
	 * Active cooling fan on PWM0 channel 10 / PB6 (vendor: 40 us period,
	 * inverted, 32 levels). #cooling-cells lets a thermal zone bind it once
	 * the A523 THS series lands; usable as a manual cooling device until then.
	 * &pwm0 is enabled via trimui-panel.dtsi.
	 */
	pwm_fan: pwm-fan {
		compatible = "pwm-fan";
		pwms = <&pwm0 10 40000 PWM_POLARITY_INVERTED>;
		#cooling-cells = <2>;
		cooling-levels = <0 1 20 30 40 50 60 70 80 90 100 110 120
				  130 140 150 160 170 180 190 200 205 210
				  215 220 225 230 235 240 245 250 255>;
	};

	/* Haptic motor on PWM0 channel 7 (vendor: 50 us period, normal). */
	vibrator {
		compatible = "pwm-vibrator";
		pwms = <&pwm0 7 50000 0>;
		pwm-names = "enable";
	};

	/*
	 * AIC8800 WiFi power/reset sequencing for the mmc1 SDIO bus. wlan_regon =
	 * PM1 (R_PIO bank 1, pin 1). The chip needs the out-of-tree aic8800 module;
	 * this only powers/resets it. ACTIVE_LOW so deassert (high) = powered on.
	 */
	wifi_pwrseq: wifi-pwrseq {
		compatible = "mmc-pwrseq-simple";
		reset-gpios = <&r_pio 1 1 GPIO_ACTIVE_LOW>;	/* PM1 wlan_regon */
		post-power-on-delay-ms = <200>;
	};
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pb_pins>;
	status = "okay";
};

/*
 * UART1 (PG6-PG9, with RTS/CTS) = AIC8800 Bluetooth HCI. The BT side needs the
 * out-of-tree aic8800 module; control lines are on R_PIO Port M: bt_rst_n = PM2,
 * bt_wake = PM3, bt_hostwake = PM4.
 */
&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_pins>, <&uart1_rts_cts_pins>;
	uart-has-rtscts;
	status = "okay";
};

/*
 * Reduced-I2C bus: main PMIC lives here (vendor "pmu@34" on s_twi0 = r_i2c0).
 * Vendor silk says AXP717C and drives it as axp2202; mainline only has an
 * AXP717 driver and the register maps are close. VERIFY the chip ID before
 * trusting any voltage below - a wrong PMIC map can mis-set rails.
 */
&r_i2c0 {
	pinctrl-names = "default";
	pinctrl-0 = <&r_i2c_pins>;
	status = "okay";

	axp717: pmic@34 {
		compatible = "x-powers,axp717";	/* VERIFY: axp717 vs axp2202 */
		reg = <0x34>;
		interrupt-controller;
		#interrupt-cells = <1>;
		interrupt-parent = <&nmi_intc>;
		interrupts = <0 IRQ_TYPE_LEVEL_LOW>;

		axp717_adc: adc {
			compatible = "x-powers,axp717-adc";
			#io-channel-cells = <1>;
		};

		battery-power {
			compatible = "x-powers,axp717-battery-power-supply";
			monitored-battery = <&battery>;
		};

		regulators {
			/* dcdc1: CPU "little" cluster (vendor cpu-supply = dcdc1). */
			reg_dcdc1: dcdc1 {
				regulator-always-on;
				regulator-min-microvolt = <900000>;
				regulator-max-microvolt = <1160000>;
				regulator-name = "vdd-cpu";
			};

			reg_dcdc2: dcdc2 {
				regulator-always-on;
				regulator-min-microvolt = <920000>;
				regulator-max-microvolt = <920000>;
				regulator-name = "vdd-gpu-sys";	/* VERIFY */
			};

			/*
			 * LPDDR4 VCC-DRAM. Datasheet Table 6-2 (Recommended
			 * Operating Conditions): 1.06 / 1.10 / 1.17 V. Use 1.10 V
			 * typ — earlier 1.16 V was wrong (copied from the CPU rail,
			 * no margin). Confirm via AXP2202 DCDC3 i2c read on HW.
			 * See uboot/DRAM-VALIDATION.md.
			 */
			reg_dcdc3: dcdc3 {
				regulator-always-on;
				regulator-min-microvolt = <1100000>;
				regulator-max-microvolt = <1100000>;
				regulator-name = "vdd-dram";
			};

			reg_dcdc4: dcdc4 {
				regulator-always-on;
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-name = "vdd-io";	/* VERIFY */
			};

			reg_aldo1: aldo1 {
				/* VERIFY connection */
			};

			reg_aldo2: aldo2 {
				/* VERIFY connection */
			};

			/* aldo3: WiFi 3.3V (vendor wlan_power[0] = aldo3 @ 3.3V). */
			reg_aldo3: aldo3 {
				regulator-always-on;
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-name = "vcc-wifi-3v3";	/* VERIFY */
			};

			reg_aldo4: aldo4 {
				regulator-always-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-name = "vcc-pll-avcc";	/* VERIFY */
			};

			/* bldo1: WiFi 1.8V (vendor wlan_power[1] = bldo1 @ 1.8V). */
			reg_bldo1: bldo1 {
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-name = "vcc-wifi-1v8";	/* VERIFY */
			};

			/* bldo2: 1.8V, vendor keeps on (wlan_power[2]). */
			reg_bldo2: bldo2 {
				regulator-always-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-name = "vcc-1v8";	/* VERIFY */
			};

			reg_bldo3: bldo3 {
				/* VERIFY connection */
			};

			reg_bldo4: bldo4 {
				/* VERIFY connection */
			};

			reg_cldo1: cldo1 {
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-name = "vcc-1v8-io";	/* VERIFY (mmc vqmmc) */
			};

			reg_cldo2: cldo2 {
				/* VERIFY connection */
			};

			reg_cldo3: cldo3 {
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-name = "vcc-3v3-io-mmc";	/* VERIFY (mmc vmmc) */
			};

			reg_cldo4: cldo4 {
				/* VERIFY connection */
			};

			reg_cpusldo: cpusldo {
				regulator-always-on;
				regulator-min-microvolt = <900000>;
				regulator-max-microvolt = <900000>;
				regulator-name = "vdd-cpus";
			};
		};
	};

	/*
	 * External "big" cluster CPU supply: TCS4838 buck @ 0x41 (vendor
	 * cpu-supply for cluster1 / cpu4-7). A FAN53555-family single-output buck,
	 * matched purely by compatible (tcs,tcs4838, added in patch 0014 — no
	 * chip-ID probe). The 0.7125-1.5 V envelope is the vendor DTB constraint;
	 * the big-cluster OPP ladder (dts/staging/trimui-cpu-opp.dtsi) caps the
	 * actual operating voltage at 1.15 V nominal. always-on: it is the live
	 * big-core rail. VERIFY on hardware (i2cdump 0x41 ID1/ID2 + live VSEL, see
	 * docs/TCS4838-NOTES.md) before trusting DVFS on this cluster.
	 */
	reg_tcs4838_dcdc0: regulator@41 {
		compatible = "tcs,tcs4838";
		reg = <0x41>;
		regulator-name = "vdd-cpu-big";
		regulator-min-microvolt = <712500>;
		regulator-max-microvolt = <1500000>;
		regulator-ramp-delay = <520>;	/* vendor DTB; driver rounds to the fan53555 500 uV/us slew */
		regulator-boot-on;
		regulator-always-on;
	};
};

/* microSD */
&mmc0 {
	pinctrl-names = "default";
	pinctrl-0 = <&mmc0_pins>;
	bus-width = <4>;
	cd-gpios = <&pio 5 6 GPIO_ACTIVE_LOW>;	/* PF6 */
	vmmc-supply = <&reg_cldo3>;	/* VERIFY */
	vqmmc-supply = <&reg_cldo1>;	/* VERIFY */
	cap-sd-highspeed;
	status = "okay";
};

/* WiFi over SDIO (vendor wlan_busnum = 1). Chip unidentified -> no child yet. */
&mmc1 {
	pinctrl-names = "default";
	pinctrl-0 = <&mmc1_pins>;
	bus-width = <4>;
	non-removable;
	vmmc-supply = <&reg_aldo3>;	/* 3.3V (vendor) */
	vqmmc-supply = <&reg_bldo1>;	/* 1.8V (vendor) */
	mmc-pwrseq = <&wifi_pwrseq>;
	keep-power-in-suspend;
	/*
	 * Chip = AIC8800 (firmware-confirmed), driven by the out-of-tree aic8800
	 * SDIO module which probes the function automatically, so no wifi@1 child
	 * with a mainline compatible. Vendor control lines on R_PIO Port M:
	 * wlan_hostwake = PM0, chip_en = PM5 (wlan_regon = PM1 -> wifi_pwrseq).
	 */
	status = "okay";
};

/* eMMC */
&mmc2 {
	pinctrl-names = "default";
	pinctrl-0 = <&mmc2_pins>;
	bus-width = <8>;
	non-removable;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	vmmc-supply = <&reg_cldo3>;	/* 3.3V VERIFY */
	vqmmc-supply = <&reg_cldo1>;	/* 1.8V VERIFY */
	status = "okay";
};

/*
 * CPU idle states (PSCI) — WFI cpu-sleep + cluster power-down, for battery life.
 * Latencies/residencies transcribed from the vendor DTB; VERIFY on hardware.
 */
/ {
	cpus {
		idle-states {
			entry-method = "psci";

			cpu_sleep: cpu-sleep {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x00010000>;
				local-timer-stop;
				entry-latency-us = <46>;
				exit-latency-us = <59>;
				min-residency-us = <3570>;
			};

			cluster_sleep: cluster-sleep {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x01010000>;
				local-timer-stop;
				entry-latency-us = <47>;
				exit-latency-us = <74>;
				min-residency-us = <5000>;
			};
		};
	};
};

&cpu0 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu1 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu2 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu3 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu4 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu5 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu6 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };
&cpu7 { cpu-idle-states = <&cpu_sleep &cluster_sleep>; };

/* USB */
&usb_otg {
	dr_mode = "otg";	/* external "usb/dp" USB-C port */
	usb-role-switch;	/* host/device role driven by the husb311 Type-C PD controller */
	status = "okay";

	port {
		usb_otg_hs_ep: endpoint {
			remote-endpoint = <&usbc_hs_ep>;
		};
	};
};

&usbphy {
	/* VERIFY id/vbus detect GPIOs + drivevbus from PMIC on hardware. */
	status = "okay";
};

&ehci0 {
	status = "okay";
};

&ohci0 {
	status = "okay";
};

/* Internal host bus - one port carries the gamepad MCU (buttons over USB). */
&ehci1 {
	status = "okay";
};

&ohci1 {
	status = "okay";
};

/*
 * USB-C Type-C port controller on the "usb/dp" port. husb311 (Hynetek) is
 * register-compatible with the Richtek RT1711H. It negotiates USB-PD (charging)
 * and drives the OTG data-role switch (usb-role-switch on &usb_otg, via the
 * sunxi musb role-switch support) so the port can host adapters as well as
 * charge / act as a gadget. VERIFY on hardware: bus/pins (i2c5 = PB11/PB12),
 * ALERT irq (PL13), the PDOs, and a vbus-supply (an AXP drive-vbus rail) if
 * bus-powered host peripherals (keyboard/mouse) are to be powered.
 */
&i2c5 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c5_pb_pins>;
	status = "okay";

	usb_pd: usb-pd@4e {
		compatible = "hynetek,husb311", "richtek,rt1711h";
		reg = <0x4e>;
		interrupt-parent = <&r_pio>;
		interrupts = <0 13 IRQ_TYPE_LEVEL_LOW>;	/* PL13, active-low ALERT */
		wakeup-source;

		connector {
			compatible = "usb-c-connector";
			label = "usb/dp";
			power-role = "dual";
			data-role = "dual";
			try-power-role = "source";
			op-sink-microwatt = <1000000>;
			/* PDOs transcribed from the vendor DTB — VERIFY on hardware. */
			sink-pdos = <0x220190c8 0x864190c8>;
			source-pdos = <0x22019032 0x86419078>;

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;
					usbc_hs_ep: endpoint {
						remote-endpoint = <&usb_otg_hs_ep>;
					};
				};
			};
		};
	};
};

&pio {
	i2c5_pb_pins: i2c5-pb-pins {
		pins = "PB11", "PB12";	/* TWI5-SCK / TWI5-SDA */
		allwinner,pinmux = <2>;
		function = "i2c5";
	};
};

/*
 * Mali-G57 (Valhall, Job-Manager) — Panfrost. Node, binding and driver are all
 * upstream; the board only enables it and supplies the rail. mali-supply =
 * AXP2202 dcdc2 (resolved from the vendor DTB; a shared GPU+VE rail). See
 * docs/GPU-NOTES.md.
 */
&gpu {
	mali-supply = <&reg_dcdc2>;
	status = "okay";
};

/*
 * Internal audio codec (driver sun55i-codec; node in sun55i-a523.dtsi). avcc =
 * analog 1.8 V = AXP2202 aldo4 (vendor avcc-supply). Speaker amp enable = PH6
 * (active high). The routing mirrors the vendor card: DAC -> line-out/HP pins,
 * speaker fed from the line-out pins, mics -> ADCs. Jack/HMIC detect is WIP
 * (see docs/AUDIO-CODEC-NOTES.md).
 */
&codec {
	allwinner,pa-gpios = <&pio 7 6 GPIO_ACTIVE_HIGH>;	/* PH6 speaker amp */
	allwinner,audio-routing =
		"LINEOUTL", "LINEOUTLP_PIN",
		"LINEOUTL", "LINEOUTLN_PIN",
		"LINEOUTR", "LINEOUTRP_PIN",
		"LINEOUTR", "LINEOUTRN_PIN",
		"SPK", "LINEOUTLP_PIN",
		"SPK", "LINEOUTLN_PIN",
		"SPK", "LINEOUTRP_PIN",
		"SPK", "LINEOUTRN_PIN",
		"HPOUT", "HPOUTL_PIN",
		"HPOUT", "HPOUTR_PIN",
		"MIC1P_PIN", "MIC1",
		"MIC1N_PIN", "MIC1",
		"MIC2P_PIN", "MIC2",
		"MIC2N_PIN", "MIC2",
		"MIC3P_PIN", "MIC3",
		"MIC3N_PIN", "MIC3";
	avcc-supply = <&reg_aldo4>;
	status = "okay";
};

/*
 * Side keys on LRADC (vendor "keyboard_1350mv", 3 keys). The per-key voltages
 * and keycodes are transcribed from the vendor DTB (key0/1/2 = <voltage_mV
 * keycode>): 410 mV / KEY_HOMEPAGE, 646 mV / KEY_VOLUMEUP, 900 mV /
 * KEY_VOLUMEDOWN. So these are the vendor's measured thresholds, not guesses —
 * confirm on HW with evtest. If a key doesn't fire, mainline's r329-LRADC scale
 * differs from the vendor 1350 mV reference: read the driver's measured voltage
 * (temporary dev_info in sun4i-lradc-keys.c) and/or fix vref-supply. See the
 * "LRADC keys" step in docs/HARDWARE-BRINGUP.md.
 */
&lradc {
	vref-supply = <&reg_bldo2>;	/* 1.8V VERIFY (LRADC reference rail) */
	status = "okay";

	button-410 {
		label = "Home";
		linux,code = <KEY_HOMEPAGE>;
		channel = <0>;
		voltage = <410000>;	/* vendor key0; confirm on HW */
	};

	button-646 {
		label = "Volume Up";
		linux,code = <KEY_VOLUMEUP>;
		channel = <0>;
		voltage = <646000>;	/* vendor key1; confirm on HW */
	};

	button-900 {
		label = "Volume Down";
		linux,code = <KEY_VOLUMEDOWN>;
		channel = <0>;
		voltage = <900000>;	/* vendor key2; confirm on HW */
	};
};

/*
 * Analog sticks via GPADC — two controllers, 2 channels each (4 axes = 2 sticks).
 * gpadc0 (adc@2009000) is upstream since v7.2; gpadc1 (adc@2009c00) is added by
 * kernel/patches (the second controller). Channel->axis mapping and abs-range are
 * BEST-GUESS: calibrate on HW (read raw min/max/centre per axis; then set
 * abs-range + abs-flat deadzone). 12-bit (0..4095). VERIFY on the device.
 */
&gpadc {		/* left stick */
	status = "okay";
};

&gpadc1 {		/* right stick (adc@2009c00, via kernel/patches) */
	status = "okay";
};

/ {
	joystick-left {
		compatible = "adc-joystick";
		io-channels = <&gpadc 0>, <&gpadc 1>;
		poll-interval = <16>;
		#address-cells = <1>;
		#size-cells = <0>;

		axis@0 {
			reg = <0>;
			linux,code = <ABS_X>;
			abs-range = <0 4095>;	/* VERIFY / calibrate */
			abs-fuzz = <16>;
			abs-flat = <128>;
		};

		axis@1 {
			reg = <1>;
			linux,code = <ABS_Y>;
			abs-range = <0 4095>;	/* VERIFY / calibrate */
			abs-fuzz = <16>;
			abs-flat = <128>;
		};
	};

	joystick-right {
		compatible = "adc-joystick";
		io-channels = <&gpadc1 0>, <&gpadc1 1>;
		poll-interval = <16>;
		#address-cells = <1>;
		#size-cells = <0>;

		axis@0 {
			reg = <0>;
			linux,code = <ABS_RX>;
			abs-range = <0 4095>;	/* VERIFY / calibrate */
			abs-fuzz = <16>;
			abs-flat = <128>;
		};

		axis@1 {
			reg = <1>;
			linux,code = <ABS_RY>;
			abs-range = <0 4095>;	/* VERIFY / calibrate */
			abs-fuzz = <16>;
			abs-flat = <128>;
		};
	};
};

&rtc {
	status = "okay";
};

/*
 * Addressable RGB LED array (17 LEDs, WS2812-style) on the LEDC controller,
 * data on PH19. The LEDC node + driver landed in mainline v7.1
 * (allwinner,sun55i-a523-ledc -> sun50i-a100-ledc). Vendor DTB: led_count=17,
 * output_mode="RGB". pixel-format defaults to grb (WS2812); flip on HW if colours
 * are swapped. VERIFY count/order against the device.
 */
&ledc {
	pinctrl-names = "default";
	pinctrl-0 = <&ledc_ph_pin>;
	status = "okay";

	multi-led@0 {
		reg = <0x0>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <0>;
	};
	multi-led@1 {
		reg = <0x1>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <1>;
	};
	multi-led@2 {
		reg = <0x2>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <2>;
	};
	multi-led@3 {
		reg = <0x3>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <3>;
	};
	multi-led@4 {
		reg = <0x4>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <4>;
	};
	multi-led@5 {
		reg = <0x5>;
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		function-enumerator = <5>;
