From fb54656fe99ab649002cf8f44c76778deb5fd65a Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Sat, 20 Jun 2026 23:43:05 +0000
Subject: [PATCH 2/8] phy: allwinner: add sun55i DSI combo D-PHY

Wire the new sun55i DSI/LVDS combo D-PHY driver into the build.
The driver source is kernel/drivers/phy-sun55i-dsi-combo.c in this repo;
drop it into drivers/phy/allwinner/ before applying this patch.

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 drivers/phy/allwinner/Kconfig  | 12 ++++++++++++
 drivers/phy/allwinner/Makefile |  1 +
 2 files changed, 13 insertions(+)

diff --git a/drivers/phy/allwinner/Kconfig b/drivers/phy/allwinner/Kconfig
index fb584518b..6328f8a87 100644
--- a/drivers/phy/allwinner/Kconfig
+++ b/drivers/phy/allwinner/Kconfig
@@ -57,3 +57,15 @@ config PHY_SUN50I_USB3
 	  part of Allwinner H6 SoC.
 
 	  This driver controls each individual USB 2+3 host PHY combo.
+
+config PHY_SUN55I_DSI_COMBO
+	tristate "Allwinner sun55i DSI/LVDS combo D-PHY Support"
+	depends on ARCH_SUNXI || COMPILE_TEST
+	depends on HAS_IOMEM && COMMON_CLK
+	depends on RESET_CONTROLLER
+	select GENERIC_PHY
+	select GENERIC_PHY_MIPI_DPHY
+	help
+	  Choose this option to support the MIPI-DSI/LVDS combo D-PHY found
+	  on Allwinner sun55i SoCs (A523/A527/T527), used to drive a
+	  MIPI-DSI display panel.
diff --git a/drivers/phy/allwinner/Makefile b/drivers/phy/allwinner/Makefile
index bd74901a1..cca415172 100644
--- a/drivers/phy/allwinner/Makefile
+++ b/drivers/phy/allwinner/Makefile
@@ -3,3 +3,4 @@ obj-$(CONFIG_PHY_SUN4I_USB)		+= phy-sun4i-usb.o
 obj-$(CONFIG_PHY_SUN6I_MIPI_DPHY)	+= phy-sun6i-mipi-dphy.o
 obj-$(CONFIG_PHY_SUN9I_USB)		+= phy-sun9i-usb.o
 obj-$(CONFIG_PHY_SUN50I_USB3)		+= phy-sun50i-usb3.o
+obj-$(CONFIG_PHY_SUN55I_DSI_COMBO)	+= phy-sun55i-dsi-combo.o
-- 
