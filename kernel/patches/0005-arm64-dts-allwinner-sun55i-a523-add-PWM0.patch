From c606cead217e5e170744f6e41845a923e839783d Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Sat, 20 Jun 2026 23:43:06 +0000
Subject: [PATCH 5/8] arm64: dts: allwinner: sun55i-a523: add PWM0

Add the PWM0 controller (PWMCTRL0 @ 0x02000c00, PWM v2 IP) used for the
panel backlight (channel 0 / PD23). Driver: pwm-sun20i. Disabled by
default, enabled per board.

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index b07cd4a54..498b535eb 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -858,6 +858,17 @@ gmac1_mtl_tx_setup: tx-queues-config {
 			};
 		};
 
+		pwm0: pwm@2000c00 {
+			compatible = "allwinner,sun55i-a523-pwm";
+			reg = <0x02000c00 0x400>;
+			clocks = <&ccu CLK_BUS_PWM0>, <&osc24M>, <&ccu CLK_APB0>;
+			clock-names = "bus", "hosc", "apb0";
+			resets = <&ccu RST_BUS_PWM0>;
+			allwinner,pwm-channels = <16>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
 		/*
 		 * Display pipeline (DE3.5 -> TCON-LCD1 -> MIPI-DSI1 -> panel).
 		 *
-- 
