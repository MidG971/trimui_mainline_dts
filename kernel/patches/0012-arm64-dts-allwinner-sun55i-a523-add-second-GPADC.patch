From 1ae190c69127227d90931dda41d1975a66aeeb47 Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Fri, 3 Jul 2026 16:49:05 +0000
Subject: [PATCH] arm64: dts: allwinner: sun55i-a523: add second GPADC
 controller

The A523 has two GPADC controllers; mainline only describes the first
(adc@2009000). Add the second, adc@2009c00, which drives the right
analog stick on handhelds such as the Trimui Smart Pro S. It is the same
IP as the first controller, with its own bus/mod clocks, reset and
interrupt. Left disabled; boards that use it enable it.

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index ca6a16807..a3b160b10 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -355,6 +355,19 @@ gpadc: adc@2009000 {
 			status = "disabled";
 		};
 
+		gpadc1: adc@2009c00 {
+			compatible = "allwinner,sun55i-a523-gpadc";
+			reg = <0x2009c00 0x400>;
+			clocks = <&ccu CLK_BUS_GPADC1>, <&ccu CLK_GPADC1>;
+			clock-names = "bus", "mod";
+			resets = <&ccu RST_BUS_GPADC1>;
+			interrupts = <GIC_SPI 64 IRQ_TYPE_LEVEL_HIGH>;
+			#io-channel-cells = <1>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+		};
+
 		wdt: watchdog@2050000 {
 			compatible = "allwinner,sun55i-a523-wdt";
 			reg = <0x2050000 0x20>;
-- 
