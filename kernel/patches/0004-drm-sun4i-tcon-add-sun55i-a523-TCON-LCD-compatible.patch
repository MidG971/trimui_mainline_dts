From 938aae96475627d35228193e9f674e76f9f49b39 Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Sat, 20 Jun 2026 23:43:06 +0000
Subject: [PATCH 4/8] drm/sun4i: tcon: add sun55i-a523 TCON-LCD compatible

The A523 (sun55iw3) TCON-LCD is the same instruction-compatible LCD timing
controller as the D1: channel-0 only, dclk_min_div = 1, and the channel-0
polarity / DSI clock-source mux is selected the same way (the BSP
sunxi_tcon.c drives mclk == pixel_clk and selects the DSI source through the
TCON-top mux). Reuse the D1 LCD quirk shape under a new compatible and add it
to the binding (same enum groups as sun20i-d1-tcon-lcd: ahb/tcon-ch0 clocks,
#clock-cells + clock-output-names, lcd+lvds resets).

Verified: compiles clean (drivers/gpu/drm/sun4i/sun4i_tcon.o, linux 6.19);
binding YAML passes dt-doc-validate.

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 .../bindings/display/allwinner,sun4i-a10-tcon.yaml  |  4 ++++
 drivers/gpu/drm/sun4i/sun4i_tcon.c                  | 13 +++++++++++++
 2 files changed, 17 insertions(+)

diff --git a/Documentation/devicetree/bindings/display/allwinner,sun4i-a10-tcon.yaml b/Documentation/devicetree/bindings/display/allwinner,sun4i-a10-tcon.yaml
index 724d93b91..659b962e1 100644
--- a/Documentation/devicetree/bindings/display/allwinner,sun4i-a10-tcon.yaml
+++ b/Documentation/devicetree/bindings/display/allwinner,sun4i-a10-tcon.yaml
@@ -34,6 +34,7 @@ properties:
       - const: allwinner,sun9i-a80-tcon-lcd
       - const: allwinner,sun9i-a80-tcon-tv
       - const: allwinner,sun20i-d1-tcon-lcd
+      - const: allwinner,sun55i-a523-tcon-lcd
       - const: allwinner,sun20i-d1-tcon-tv
 
       - items:
@@ -234,6 +235,7 @@ allOf:
               - allwinner,sun8i-v3s-tcon
               - allwinner,sun9i-a80-tcon-lcd
               - allwinner,sun20i-d1-tcon-lcd
+              - allwinner,sun55i-a523-tcon-lcd
 
     then:
       properties:
@@ -281,6 +283,7 @@ allOf:
               - allwinner,sun4i-a10-tcon
               - allwinner,sun8i-a83t-tcon-lcd
               - allwinner,sun20i-d1-tcon-lcd
+              - allwinner,sun55i-a523-tcon-lcd
 
     then:
       required:
@@ -298,6 +301,7 @@ allOf:
               - allwinner,sun8i-a33-tcon
               - allwinner,sun8i-a83t-tcon-lcd
               - allwinner,sun20i-d1-tcon-lcd
+              - allwinner,sun55i-a523-tcon-lcd
 
     then:
       properties:
diff --git a/drivers/gpu/drm/sun4i/sun4i_tcon.c b/drivers/gpu/drm/sun4i/sun4i_tcon.c
index 960e83c82..424803a7e 100644
--- a/drivers/gpu/drm/sun4i/sun4i_tcon.c
+++ b/drivers/gpu/drm/sun4i/sun4i_tcon.c
@@ -1542,6 +1542,18 @@ static const struct sun4i_tcon_quirks sun20i_d1_lcd_quirks = {
 	.set_mux		= sun8i_r40_tcon_tv_set_mux,
 };
 
+/*
+ * The A523 (sun55iw3) TCON-LCD is the same instruction-compatible LCD timing
+ * controller as the D1: channel-0 only, dclk_min_div = 1, and the channel-0
+ * polarity/DSI clock-source mux is selected the same way (the BSP sunxi_tcon.c
+ * drives mclk == pixel_clk and picks the DSI source via the TCON top mux).
+ */
+static const struct sun4i_tcon_quirks sun55i_a523_lcd_quirks = {
+	.has_channel_0		= true,
+	.dclk_min_div		= 1,
+	.set_mux		= sun8i_r40_tcon_tv_set_mux,
+};
+
 /* sun4i_drv uses this list to check if a device node is a TCON */
 const struct of_device_id sun4i_tcon_of_table[] = {
 	{ .compatible = "allwinner,sun4i-a10-tcon", .data = &sun4i_a10_quirks },
@@ -1560,6 +1572,7 @@ const struct of_device_id sun4i_tcon_of_table[] = {
 	{ .compatible = "allwinner,sun9i-a80-tcon-lcd", .data = &sun9i_a80_tcon_lcd_quirks },
 	{ .compatible = "allwinner,sun9i-a80-tcon-tv", .data = &sun9i_a80_tcon_tv_quirks },
 	{ .compatible = "allwinner,sun20i-d1-tcon-lcd", .data = &sun20i_d1_lcd_quirks },
+	{ .compatible = "allwinner,sun55i-a523-tcon-lcd", .data = &sun55i_a523_lcd_quirks },
 	{ .compatible = "allwinner,sun20i-d1-tcon-tv", .data = &sun8i_r40_tv_quirks },
 	{ }
 };
