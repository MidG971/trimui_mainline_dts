From acadf6674a48bbe4c1b1330c184b22d304e33aea Mon Sep 17 00:00:00 2001
From: Midgy BALON <midgy971@gmail.com>
Date: Sun, 21 Jun 2026 08:16:46 +0000
Subject: [PATCH] ASoC: sunxi: wire up the A523 audio codec

Add the Kconfig symbol and Makefile object for the new Allwinner A523
(sun55iw3) internal audio codec driver (sun55i-codec).

Signed-off-by: Midgy BALON <midgy971@gmail.com>
---
 sound/soc/sunxi/Kconfig  | 9 +++++++++
 sound/soc/sunxi/Makefile | 1 +
 2 files changed, 10 insertions(+)

diff --git a/sound/soc/sunxi/Kconfig b/sound/soc/sunxi/Kconfig
index 205f422d9..73325b4cc 100644
--- a/sound/soc/sunxi/Kconfig
+++ b/sound/soc/sunxi/Kconfig
@@ -68,3 +68,12 @@ config SND_SUN8I_ADDA_PR_REGMAP
 	select REGMAP
 
 endmenu
+
+config SND_SOC_SUN55I_CODEC
+	tristate "Allwinner A523 Codec Support"
+	depends on ARCH_SUNXI || COMPILE_TEST
+	select SND_SOC_GENERIC_DMAENGINE_PCM
+	select REGMAP_MMIO
+	help
+	  Select Y or M to add support for the internal audio codec found on
+	  the Allwinner A523 (sun55iw3) family of SoCs.
diff --git a/sound/soc/sunxi/Makefile b/sound/soc/sunxi/Makefile
index 4483fe9c9..0fa387c2a 100644
--- a/sound/soc/sunxi/Makefile
+++ b/sound/soc/sunxi/Makefile
@@ -7,3 +7,4 @@ obj-$(CONFIG_SND_SUN50I_CODEC_ANALOG) += sun50i-codec-analog.o
 obj-$(CONFIG_SND_SUN8I_CODEC) += sun8i-codec.o
 obj-$(CONFIG_SND_SUN8I_ADDA_PR_REGMAP) += sun8i-adda-pr-regmap.o
 obj-$(CONFIG_SND_SUN50I_DMIC) += sun50i-dmic.o
+obj-$(CONFIG_SND_SOC_SUN55I_CODEC) += sun55i-codec.o
-- 
2.39.5

