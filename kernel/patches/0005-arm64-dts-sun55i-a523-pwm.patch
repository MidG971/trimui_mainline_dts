Subject: [PATCH] arm64: dts: allwinner: sun55i-a523: add PWM0

Add the PWM0 controller (PWMCTRL0 @ 0x02000c00, PWM v2 IP) used for the
panel backlight (channel 0 / PD23). Driver: pwm-sun20i. Disabled by
default, enabled per board.

Apply with: patch -p1 < this file

--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -858,6 +858,17 @@
 			};
 		};
 
+		pwm0: pwm@2000c00 {
+			compatible = "allwinner,sun55i-a523-pwm";
+			reg = <0x02000c00 0x400>;
+			clocks = <&ccu CLK_BUS_PWM0>, <&osc24M>, <&ccu CLK_APB0>;
+			clock-names = "bus", "hosc", "apb0";
+			resets = <&ccu RST_BUS_PWM0>;
+			allwinner,pwm-channels = <16>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
 		/*
 		 * Display pipeline (DE3.5 -> TCON-LCD1 -> MIPI-DSI1 -> panel).
 		 *
